# =============================================================================
# Enterprise Retail Analytics Platform - .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Generated Data (produced by Python/generate_dataset.py)
# ---------------------------------------------------------------------------
Dataset/*.csv
Dataset/*.xlsx
Dataset/*.parquet

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
env/
.env
.env.*
*.egg-info/
dist/
build/
.eggs/

# ---------------------------------------------------------------------------
# Power BI (binary report files - too large for Git)
# ---------------------------------------------------------------------------
*.pbix
*.pbit

# ---------------------------------------------------------------------------
# IDE / Editor
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
*.log
*.tmp
*.bak

# ---------------------------------------------------------------------------
# Jupyter Notebooks (checkpoints)
# ---------------------------------------------------------------------------
.ipynb_checkpoints/

# ---------------------------------------------------------------------------
# NOTE: .gitkeep files are retained so empty directories are tracked by Git.
# ---------------------------------------------------------------------------
